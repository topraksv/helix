# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
dist-local/
web-build/
expo-env.d.ts

# local test artifacts / scratch (headless screenshots, browser profiles, sample sheets)
# Sample sheets are ignored only at the repo root so committed test fixtures
# (e.g. tests/fixtures/*.xlsx) remain possible.
vshots/
profile-*/
/*.xlsm
/*.xlsx

# Native (incl. signing material — never commit keys/certs)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# local env files
.env*.local

# Supabase CLI local link/cache state
supabase/.temp/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# local secrets
.env
.env.eas-simulator
