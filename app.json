{
  "expo": {
    "name": "Helix",
    "slug": "helix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "helix",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.toprak.helix",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.developer.default-data-protection": "NSFileProtectionComplete"
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Finansal verilerinizi korumak için Face ID ile kilit açma kullanılır."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#faf9f5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf9f5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 130,
          "dark": {
            "backgroundColor": "#141413",
            "image": "./assets/images/splash-icon-dark.png"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {}
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/helix"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f71b0477-c800-45cc-903a-9b4d32a9c6b4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f71b0477-c800-45cc-903a-9b4d32a9c6b4"
    }
  }
}
